<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- HANYA 1 akses untuk modul Work Order Mold (tidak ada Full/Read-only).
         - implied base.group_user: pemilik grup otomatis Internal User.
         - admin dimasukkan agar tetap bisa melihat & mengelola.
         Akses diberikan admin lewat Master User. -->
    <record id="group_work_orders_mold" model="res.groups">
        <field name="name">Akses Work Order Mold</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
