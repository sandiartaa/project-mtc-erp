<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record rule: grup Work Order Mold hanya boleh melihat/mengelola WO
         bertipe mold dari model bersama wo.work.order. Aturan per-grup di-OR,
         jadi user app Work Orders utama (Full/Read-only) tetap melihat semua. -->
    <record id="rule_wom_mold" model="ir.rule">
        <field name="name">Work Order Mold: hanya WO bertipe Mold</field>
        <field name="model_id" ref="custom_work_orders.model_wo_work_order"/>
        <field name="groups" eval="[(4, ref('group_work_orders_mold'))]"/>
        <field name="domain_force">[('wo_type', '=', 'mold')]</field>
    </record>
</odoo>
