<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Grup akses modul SPK.
         - implied base.group_user: pemilik grup otomatis jadi Internal User.
         - admin (base.user_admin) ikut dimasukkan agar tetap bisa melihat SPK. -->
    <record id="group_spk_user" model="res.groups">
        <field name="name">Akses SPK</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
