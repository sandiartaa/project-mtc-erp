<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Grup akses modul Penjualan.
         - implied base.group_user: pemilik grup otomatis jadi Internal User.
         - admin ikut dimasukkan agar tetap bisa melihat Penjualan.
         Catatan: SENGAJA tidak mewarisi grup Sales bawaan, supaya app "Sales"
         bawaan tidak ikut muncul. Hak baca/tulis data Sales diberikan lewat
         ir.model.access (read only data, app tetap tersembunyi). -->
    <record id="group_penjualan_user" model="res.groups">
        <field name="name">Akses Penjualan</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
